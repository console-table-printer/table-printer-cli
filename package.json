{
  "name": "table-printer-cli",
  "version": "0.0.0",
  "description": "console table printer cli. Print table on bash terminal",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ctp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/test/**/*"
  ],
  "scripts": {
    "setup": "npm install",
    "build": "tsc",
    "lint": "eslint --ext=js,ts .",
    "format": "prettier --write \"**/*.{json,md,ts,tsx,yml,js,jsx}\"",
    "test": "jest --config jestconfig.json",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/console-table-printer/table-printer-cli.git"
  },
  "keywords": [
    "console-table",
    "console-log",
    "print-table",
    "cli"
  ],
  "author": "Nahiyan Kamal",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/console-table-printer/table-printer-cli/issues"
  },
  "homepage": "https://console-table.netlify.app/docs/doc-cli-install-quick-start",
  "dependencies": {
    "commander": "^15.0.0",
    "console-table-printer": "^2.16.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
